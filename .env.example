# Frontend runtime config (Vite). Copy to `.env.local` to override.

# Which backend the SPA talks to:
#   mock  -> in-app mock API + WS simulator (default; demoable with no backend)
#   real  -> the deployed Caneca Worker (/api/*, /ws/*) once Devs B/C/D ship it
VITE_API_MODE=mock

# Cloudflare Turnstile site key (TASKS.md §2). Defaults to the Turnstile TEST
# "always passes" key when unset. Set the real key for the deployed build.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
