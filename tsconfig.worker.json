{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "./worker-configuration.d.ts",
      "@cloudflare/vitest-pool-workers/types"
    ]
  },
  "include": [
    "src/assessment.ts",
    "src/durable-object.ts",
    "src/index.ts",
    "src/map-submissions.ts",
    "src/pubs.ts",
    "src/results.ts",
    "src/upload.ts",
    "src/worker-types.ts",
    "src/workflow.ts",
    "worker/**/*.ts",
    "test/**/*.ts",
    "worker-configuration.d.ts"
  ]
}
