{
  "name": "canecas-photo-pipeline",
  "version": "0.1.0",
  "private": true,
  "description": "Caneca pub map and Workers AI photo-rating pipeline",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "npm run typecheck && npm test && npm run build && wrangler deploy --dry-run",
    "dev": "wrangler dev",
    "dev:ui": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.worker.json && tsc -b",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.7",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "typescript": "7.0.2",
    "vite": "^8.1.5",
    "vitest": "4.1.10",
    "wrangler": "4.113.0"
  },
  "dependencies": {
    "hono": "^4.12.31",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^4.7.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-leaflet": "^5.0.0"
  }
}
