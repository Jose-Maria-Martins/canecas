{
  "name": "caneca",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Caneca — pub crawl web app (map/frontend layer)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "worker:dev": "wrangler dev",
    "worker:dry-run": "wrangler deploy --dry-run",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply caneca_db --local",
    "db:migrate": "wrangler d1 migrations apply caneca_db --remote"
  },
  "dependencies": {
    "hono": "^4.12.31",
    "maplibre-gl": "^4.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260722.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wrangler": "^4.113.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "workerd@1.20260721.1": true,
    "esbuild@0.28.1": true
  }
}
